        <view>
          <datasources>
            <datasource caption='Fact_Action_Risk+ (Farm_System_DWH)' name='federated.13fjfd10j6bqex1dj3t6804ewgz9' />
          </datasources>
          <datasource-dependencies datasource='federated.13fjfd10j6bqex1dj3t6804ewgz9'>
            <column caption='Open Alerts' datatype='integer' name='[Calculation_0855713905774595]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNTD(IF [alert_status] = &quot;new&quot; THEN [alert_sk (Dim_Alert)] END)' />
            </column>
            <column aggregation='Sum' caption='alert sk (Dim Alert)' datatype='integer' name='[alert_sk (Dim_Alert)]' role='dimension' type='ordinal' />
            <column caption='Alert Status' datatype='string' name='[alert_status]' role='dimension' type='nominal'>
              <aliases>
                <alias key='&quot;acknowledged&quot;' value='Acknowledged' />
                <alias key='&quot;new&quot;' value='New' />
                <alias key='&quot;resolved&quot;' value='Resolved' />
