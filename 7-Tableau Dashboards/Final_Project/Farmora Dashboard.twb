      <table>
        <view>
          <datasources>
            <datasource caption='Fact_Monitoring+ (Farm_System_DWH)' name='federated.1yrqbaf1r20xuw1gwt3dx1kkncab' />
          </datasources>
          <datasource-dependencies datasource='federated.1yrqbaf1r20xuw1gwt3dx1kkncab'>
            <column caption='Full Date_2' datatype='date' name='[Calculation_0369179163684864]' role='dimension' type='quantitative'>
              <calculation class='tableau' formula='DATE(STR([year]) + &quot;-&quot; + STR([mounth]) + &quot;-&quot; + STR([Day]))' />
            </column>
            <column datatype='integer' name='[Day]' role='dimension' type='quantitative' />
            <column-instance column='[reading_temperture]' derivation='Avg' name='[avg:reading_temperture:qk]' pivot='key' type='quantitative' />
            <column caption='Mounth' datatype='integer' name='[mounth]' role='measure' type='quantitative' />
