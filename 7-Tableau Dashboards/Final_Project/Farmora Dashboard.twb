      <aliases enabled='yes' />
      <column aggregation='Sum' caption='Assest catalog sk' datatype='integer' name='[Assest_catalog_sk]' role='dimension' type='ordinal' />
      <column caption='COUNT Animal Medicine' datatype='integer' name='[Calculation_1576168452190208]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([animal_medicine_id])' />
      </column>
      <column caption='AVG Animal Dosage' datatype='real' name='[Calculation_1576168452788225]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([animal_dosage])' />
      </column>
      <column caption='Yield Quality Index' datatype='real' name='[Calculation_1576168453378050]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([harvest_quality_score] * [harvest_quantity_kg]) / SUM([harvest_quantity_kg])' />
      </column>
      <column caption='Medicine coverage %' datatype='real' name='[Calculation_1576168453545987]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF NOT ISNULL([animal_medicine_id]) THEN [production_sk] END)&#13;&#10;/ COUNTD([production_sk])' />
      </column>
      <column caption='Stock status' datatype='string' name='[Calculation_1576168453681156]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([current_stock]) &lt; SUM([reorder_level]) THEN &quot;Low stock&quot;&#13;&#10;ELSEIF SUM([current_stock]) &lt; SUM([reorder_level]) * 1.2 THEN &quot;Warning&quot;&#13;&#10;ELSE &quot;OK&quot; END' />
      </column>
      <column caption='Eggs per flock' datatype='real' name='[Calculation_1576168453820421]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([eggs_collected]) / SUM([flock_size])' />
      </column>
      <column caption='Stock Alert' datatype='string' name='[Calculation_1576168455856134]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [current_stock] &lt; ([reorder_level] * 0.3) THEN&#13;&#10;  &quot;🔴 CRITICAL&quot;&#13;&#10;ELSEIF [current_stock] &lt; [reorder_level] THEN&#13;&#10;  &quot;🟡 LOW&quot;&#13;&#10;ELSEIF [current_stock] &gt; ([reorder_level] * 2) THEN&#13;&#10;  &quot;🟢 OPTIMAL&quot;&#13;&#10;ELSE&#13;&#10;  &quot;🟠 MONITOR&quot;&#13;&#10;END' />
      </column>
      <column caption=' Stock_Utilization_%' datatype='real' name='[Calculation_1576168456015879]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF SUM([current_stock]) = 0 THEN 0&#13;&#10;ELSE&#13;&#10;  (SUM([quantity_cattle_used]) + &#13;&#10;   SUM([quantity_crop_used]) + &#13;&#10;   SUM([quantity_poultry_used])) &#13;&#10;  / (SUM([current_stock]) + SUM([quantity_cattle_used]) + &#13;&#10;     SUM([quantity_crop_used]) + SUM([quantity_poultry_used])) * 100&#13;&#10;END' />
      </column>
      <column caption='Health_Status_Category' datatype='string' name='[Calculation_1576168458903562]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF AVG([health_score]) &gt;= 8.5 THEN &quot;Excellent&quot;&#13;&#10;ELSEIF AVG([health_score]) &gt;= 7.5 THEN &quot;Good&quot;&#13;&#10;ELSEIF AVG([health_score]) &gt;= 6.0 THEN &quot;Fair&quot;&#13;&#10;ELSE &quot;Poor&quot;&#13;&#10;END' />
      </column>
      <column caption='Quality_Catogary' datatype='string' name='[Calculation_1576168459026443]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF AVG([harvest_quality_score]) &gt;= 8 THEN &quot;Excellent&quot;&#13;&#10;ELSEIF AVG([harvest_quality_score]) &gt;= 6 THEN &quot;Good&quot;&#13;&#10;ELSEIF AVG([harvest_quality_score]) &gt;= 4 THEN &quot;Fair&quot;&#13;&#10;ELSE &quot;Poor&quot;&#13;&#10;END' />
      </column>
      <column caption='Production_Status' datatype='string' name='[Calculation_1576168459214860]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([crop_quantity_kg]) &gt; 0 AND SUM([eggs_collected]) &gt; 0 THEN &quot;Active Production&quot;&#13;&#10;ELSEIF SUM([crop_quantity_kg]) &gt; 0 THEN &quot;Crop Only&quot;&#13;&#10;ELSEIF SUM([eggs_collected]) &gt; 0 THEN &quot;Poultry Only&quot;&#13;&#10;ELSE &quot;Idle&quot;&#13;&#10;END' />
      </column>
      <column caption='Medicine_Admin_Rate_%' datatype='real' name='[Calculation_1576168459571213]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IFNULL(&#13;&#10;  (SUM(INT([animal_administered])) + SUM(INT([poultry_administered])))&#13;&#10;  /&#13;&#10;  (COUNTD([animal_type]) + COUNTD([Poultry_id]))&#13;&#10;  * 100&#13;&#10;, 0)' />
      </column>
      <column caption='Growth_Stage_Priority' datatype='integer' name='[Calculation_1576168459800590]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [growth_stage]&#13;&#10;WHEN &apos;Early&apos; THEN 1&#13;&#10;WHEN &apos;Growth&apos; THEN 2&#13;&#10;WHEN &apos;Mature&apos; THEN 3&#13;&#10;ELSE 4&#13;&#10;END' />
      </column>
      <column caption='MoM_Change' datatype='real' name='[Calculation_1576168464506895]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([crop_quantity_kg]) - LOOKUP(SUM([crop_quantity_kg]),-1)) / ABS(LOOKUP(SUM([crop_quantity_kg]),-1))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='color ' datatype='string' name='[Calculation_1576168466841616]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF AVG([health_score]) &gt; 8 THEN &quot;#AFD91A&quot; ELSEIF AVG([health_score]) &gt;= 6 THEN &quot;#f5b342&quot; ELSE &quot;#f56342&quot; END' />
      </column>
      <column caption='date' datatype='date' name='[Calculation_1576168799506450]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATE(&#13;&#10;  STR(INT(LEFT(STR([date_sk]), 4))) + &quot;-&quot; +&#13;&#10;  STR(INT(MID(STR([date_sk]), 5, 2))) + &quot;-&quot; +&#13;&#10;  STR(INT(RIGHT(STR([date_sk]), 2)))&#13;&#10;)' />
      </column>
      <column caption='Date_proper' datatype='date' name='[Calculation_1576168806850579]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATE(&#13;&#10;  STR(INT(LEFT(STR([date_sk]), 4))) + &quot;-&quot; +&#13;&#10;  STR(INT(MID(STR([date_sk]), 5, 2))) + &quot;-&quot; +&#13;&#10;  STR(INT(RIGHT(STR([date_sk]), 2)))&#13;&#10;)' />
      </column>
