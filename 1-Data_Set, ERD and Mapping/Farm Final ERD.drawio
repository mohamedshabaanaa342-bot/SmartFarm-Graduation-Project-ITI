        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;erDiagram\n    Customer {\n        int customer_id PK\n        string name\n        string customer_type\n        string email\n        string address\n    }\n\n    Orders {\n        int order_id PK\n        int customer_id FK\n        date order_date\n        string status\n        decimal total_amount\n    }\n\n    Order_Items {\n        int item_id PK\n        int order_id FK\n        int harvest_id FK\n        int quantity\n        decimal unit_price\n    }\n\n    Zone {\n        int zone_id PK\n        string zone_name\n        string location\n        float solar_battery_voltage\n        string zone_type\n    }\n\n    Aquarium {\n        int aquarium_id PK\n        int zone_id FK\n        string aquarium_name\n        float capacity_liters\n        string water_type\n        string location_desc\n        string status\n    }\n\n    Fish {\n        int fish_id PK\n        int aquarium_id FK\n        string species\n        string fish_type\n        float stock_kg\n        int stock_count\n        date stocked_date\n        string health_status\n        string feeding_schedule\n        string notes\n    }\n\n    Fish_Health_Log {\n        int health_log_id PK\n        int fish_id FK\n        date log_date\n        string condition_noted\n        string treatment_applied\n        float water_temp_c\n        float water_ph\n        float water_oxygen_ppm\n    }\n\n    Cattle {\n        int cattle_id PK\n        int zone_id FK\n        string species\n        string breed\n        date birth_date\n        string health_stage\n        string status\n    }\n\n    Animal_Medicine {\n        int med_id PK\n        int cattle_id FK \&quot;nullable\&quot;\n        int poultry_id FK \&quot;nullable\&quot;\n        int fish_id FK \&quot;nullable\&quot;\n        string medicine_name\n        string dosage\n        date given_date\n        string administered_by\n    }\n\n    Crop_Yield_Log {\n        int record_id PK\n        int zone_id FK\n        int crop_id FK \&quot;nullable\&quot;\n        string crop_name\n        float quantity_kg\n        date log_date\n    }\n\n    Poultry {\n        int poultry_id PK\n        int zone_id FK\n        string breed\n        string purpose\n        int flock_size\n    }\n\n    Poultry_Logs {\n        int egg_log_id PK\n        int zone_id FK\n        int poultry_id FK\n        int eggs_collected\n        date log_date\n    }\n\n    Environment_Daily_Summary {\n        bigint summary_id PK\n        int zone_id FK\n        date summary_date\n        float avg_temperature_c\n        float avg_humidity\n    }\n\n    Greenhouse {\n        int greenhouse_id PK\n        int zone_id FK\n        string name\n        float area_size\n        string status\n    }\n\n    Crop {\n        int crop_id PK\n        int zone_id FK\n        int greenhouse_id FK \&quot;nullable\&quot;\n        string crop_name\n        string variety\n        date planting_date\n        string growth_stage\n        float health_score\n    }\n\n    Harvest {\n        int harvest_id PK\n        int crop_id FK\n        date harvest_date\n        float quantity_kg\n        float quality_score\n    }\n\n    Irrigation_Log {\n        int ir_id PK\n        int crop_id FK\n        datetime timestamp\n        float water_used_liters\n    }\n\n    Soil_Daily_Summary {\n        bigint summary_id PK\n        int zone_id FK\n        int crop_id FK \&quot;nullable\&quot;\n        date summary_date\n        float avg_soil_moisture_pct\n        float avg_soil_ph\n        float avg_soil_salinity\n    }\n\n    Sensor {\n        int sensor_id PK\n        int zone_id FK\n        int aquarium_id FK \&quot;nullable_xor_crop\&quot;\n        int crop_id FK \&quot;nullable_xor_aquarium\&quot;\n        string serial_number\n        string sensor_type\n        string status\n        date last_calibrated\n    }\n\n    SensorReading {\n        int reading_id PK\n        int sensor_id FK\n        datetime reading_time\n        float temperature\n        float humidity\n        float soil_moisture\n        float soil_ph\n        float water_ph\n        float water_level\n        float rainfall_mm\n        boolean is_anomaly\n    }\n\n    Alert {\n        int alert_id PK\n        int sensor_reading_id FK\n        int zone_id FK\n        int assigned_employee_id FK\n        string alert_type\n        string severity\n        string status\n    }\n\n    Recommendation {\n        int rec_id PK\n        int alert_id FK\n        string suggested_action\n        string priority\n    }\n\n    ActionLog {\n        int log_id PK\n        int alert_id FK\n        int employee_id FK\n        datetime executed_at\n        string action_taken\n    }\n\n    Weather {\n        int weather_id PK\n        int zone_id FK\n        date recorded_date\n        string source\n        float rainfall_mm\n        float temperature\n    }\n\n    Offers {\n        int offer_id PK\n        int order_id FK\n        string offer_name\n        float discount_pct\n    }\n\n    Supplier {\n        int supplier_id PK\n        string company_name\n        string material_type\n        string phone\n        float rating\n    }\n\n    Resource {\n        int resource_id PK\n        string resource_name\n        string resource_type\n        float current_stock\n        float reorder_level\n    }\n\n    Purchase {\n        int purchase_id PK\n        int supplier_id FK\n        date purchase_date\n        decimal total_amount\n    }\n\n    Purchase_Items {\n        int item_id PK\n        int purchase_id FK\n        int resource_id FK\n        float quantity\n        decimal unit_cost\n    }\n\n    Department {\n        int dept_id PK\n        int zone_id FK \&quot;nullable\&quot;\n        string dept_name\n    }\n\n    Employee {\n        int employee_id PK\n        int zone_id FK\n        int dept_id FK\n        string full_name\n        string role\n        decimal monthly_salary\n    }\n\n    %% Relationships\n    Customer ||--o{ Orders : \&quot;places\&quot;\n    Orders ||--|{ Order_Items : \&quot;contains\&quot;\n    Orders ||--o{ Offers : \&quot;receives\&quot;\n    Harvest ||--o{ Order_Items : \&quot;sold via\&quot;\n\n    Zone ||--o{ Aquarium : \&quot;receives\&quot;\n    Zone ||--o{ Cattle : \&quot;houses\&quot;\n    Zone ||--o{ Crop_Yield_Log : \&quot;records\&quot;\n    Zone ||--o{ Poultry : \&quot;houses\&quot;\n    Zone ||--o{ Environment_Daily_Summary : \&quot;summarizes\&quot;\n    Zone ||--o{ Greenhouse : \&quot;contains\&quot;\n    Zone ||--o{ Weather : \&quot;records\&quot;\n    Zone ||--o{ Purchase : \&quot;provides\&quot;\n    Zone ||--o{ Department : \&quot;has\&quot;\n    Zone ||--o{ Employee : \&quot;employs\&quot;\n    Zone ||--o{ Alert : \&quot;receives\&quot;\n\n    Aquarium ||--|{ Fish : \&quot;contains\&quot;\n    Fish ||--o{ Fish_Health_Log : \&quot;has\&quot;\n    Fish ||--o{ Animal_Medicine : \&quot;receives\&quot;\n    Cattle ||--o{ Animal_Medicine : \&quot;receives\&quot;\n    Poultry ||--o{ Animal_Medicine : \&quot;receives\&quot;\n\n    Poultry ||--o{ Poultry_Logs : \&quot;records\&quot;\n    Zone ||--o{ Poultry_Logs : \&quot;houses\&quot;\n\n    Greenhouse ||--o{ Crop : \&quot;hosts\&quot;\n    Crop ||--o{ Crop_Yield_Log : \&quot;logs\&quot;\n    Crop ||--o{ Harvest : \&quot;yields\&quot;\n    Crop ||--o{ Irrigation_Log : \&quot;drives\&quot;\n    Crop ||--o{ Soil_Daily_Summary : \&quot;contributes\&quot;\n    Zone ||--o{ Soil_Daily_Summary : \&quot;summarizes\&quot;\n\n    Sensor ||--o{ SensorReading : \&quot;generates\&quot;\n    SensorReading ||--o{ Alert : \&quot;triggers\&quot;\n    Alert ||--o{ Recommendation : \&quot;receives\&quot;\n    Alert ||--o{ ActionLog : \&quot;executes\&quot;\n    Employee ||--o{ ActionLog : \&quot;executes\&quot;\n    Employee ||--o{ Alert : \&quot;assigned to\&quot;\n\n    Supplier ||--o{ Purchase : \&quot;has\&quot;\n    Purchase ||--|{ Purchase_Items : \&quot;contains\&quot;\n    Resource ||--o{ Purchase_Items : \&quot;fulfills\&quot;\n\n    Department ||--o{ Employee : \&quot;employs\&quot;&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="3as4aL27iG6ZnaIN8nh8-1">
