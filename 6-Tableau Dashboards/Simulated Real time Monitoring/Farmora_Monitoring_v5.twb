      <aliases enabled='yes' />
      <column caption='Full Date_2' datatype='date' name='[Calculation_0369179163684864]' role='dimension' type='quantitative'>
        <calculation class='tableau' formula='DATE(STR([year]) + &quot;-&quot; + STR([mounth]) + &quot;-&quot; + STR([Day]))' />
      </column>
      <column caption='Active GH %' datatype='real' name='[Calculation_0369179194953729]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='ROUND(&#13;&#10;  100.0 * &#13;&#10;  COUNTD(IF [greenhouse_status] = &apos;Active&apos; &#13;&#10;         THEN [greenhouse_id] END) &#13;&#10;  / COUNTD([greenhouse_id]), &#13;&#10;  1&#13;&#10;)' />
      </column>
      <column caption='Sensor Uptime %' datatype='real' name='[Calculation_0369179197206530]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='ROUND(&#13;&#10;  100.0 * &#13;&#10;  COUNTD(IF [sensor_status] = &apos;Active&apos; &#13;&#10;         THEN [sensor_id] END) &#13;&#10;  / COUNTD([sensor_id]), &#13;&#10;  1&#13;&#10;)' />
      </column>
      <column caption='Anomaly Count' datatype='integer' name='[Calculation_0369179197280259]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [reading_is_anomaly] = 1 THEN 1 ELSE 0 END)' />
      </column>
      <column caption='Total Water Usage' datatype='real' name='[Calculation_0369179201441796]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='ROUND(SUM([water_used_liters]), 0)' />
      </column>
      <column caption='Time Axis' datatype='datetime' name='[Calculation_1324655310630912]' role='dimension' type='quantitative'>
        <calculation class='tableau' formula='DATEADD(&apos;second&apos;, [second], DATEADD(&apos;minute&apos;, [minte], DATEADD(&apos;hour&apos;, [hour], #2020-01-01#)))' />
      </column>
      <column caption='Time Axis 15min' datatype='datetime' name='[Calculation_1508823764451328]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATEADD(&apos;minute&apos;,&#13;&#10;    FLOOR(DATEDIFF(&apos;minute&apos;, #2020-01-01#, [Calculation_1324655310630912]) / 15) * 15,&#13;&#10;    #2020-01-01#&#13;&#10;)' />
      </column>
