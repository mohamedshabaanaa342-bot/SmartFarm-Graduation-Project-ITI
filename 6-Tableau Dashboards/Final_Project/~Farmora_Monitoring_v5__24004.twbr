      <aliases enabled='yes' />
      <column aggregation='Sum' caption='Assest catalog sk' datatype='integer' name='[Assest_catalog_sk]' role='dimension' type='ordinal' />
      <column caption='Total Alerts' datatype='integer' name='[Calculation_0855713904336898]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([alert_sk (Dim_Alert)])' />
      </column>
      <column caption='Open Alerts' datatype='integer' name='[Calculation_0855713905774595]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [alert_status] = &quot;new&quot; THEN [alert_sk (Dim_Alert)] END)' />
      </column>
      <column caption='Critical Alerts' datatype='integer' name='[Calculation_0855713906372612]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [severity] = &quot;Critical&quot; THEN [alert_sk (Dim_Alert)] END)' />
      </column>
      <column caption='Resolve Rate %' datatype='real' name='[Calculation_0855713906614277]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [alert_status] = &quot;resolved&quot; THEN [alert_sk (Dim_Alert)] END)&#13;&#10;/&#13;&#10;COUNTD([alert_sk (Dim_Alert)])' />
      </column>
      <column caption='Total Actions' datatype='integer' name='[Calculation_0855713906790406]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([action_id])' />
      </column>
      <column caption='High Priority Actions' datatype='integer' name='[Calculation_0855713907187719]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF [priority] = &quot;p3&quot; THEN [action_id] END)' />
      </column>
      <column caption='Critical Unresolved' datatype='integer' name='[Calculation_0855713907490824]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNt(IF [severity] = &quot;Critical&quot; AND [alert_status] = &quot;new&quot; THEN [alert_sk (Dim_Alert)] END)' />
      </column>
      <column caption='Action Taken Rate %' datatype='real' name='[Calculation_0855713908191241]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([alert_sk]) / [Calculation_0855713904336898]' />
      </column>
      <column caption='Staff Closure Rate %' datatype='real' name='[Calculation_0855713908310026]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF [alert_status] = &quot;Resolved&quot; THEN [action_id] END)&#13;&#10;/&#13;&#10;COUNT([action_id])' />
      </column>
