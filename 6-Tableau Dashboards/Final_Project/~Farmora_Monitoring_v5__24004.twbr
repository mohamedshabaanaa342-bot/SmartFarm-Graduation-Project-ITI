            <column-instance column='[Calculation_0369179197206530]' derivation='User' name='[usr:Calculation_0369179197206530:qk]' pivot='key' type='quantitative' />
            <column caption='Year' datatype='integer' name='[year]' role='dimension' type='quantitative' />
