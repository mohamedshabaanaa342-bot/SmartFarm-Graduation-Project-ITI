  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>Farmora_Cube_DataSource</DataSourceName>
        <CommandText>SELECT
  NON EMPTY
  {
    [Measures].[Revenue Amount],
    [Measures].[Purchase Amount],
    [Measures].[Estimated Gross Profit],
    [Measures].[Net Cash Flow Amount]
  } ON COLUMNS,

  NON EMPTY
  (
    [Dim Date].[Year].[Year].MEMBERS
    *
    [Dim Date].[Month].[Month].MEMBERS
  )
  DIMENSION PROPERTIES
    MEMBER_CAPTION,
    MEMBER_UNIQUE_NAME
  ON ROWS

FROM [Farmora_Commercial_Cube]</CommandText>
