      <MdxScripts>
        <MdxScript>
          <ID>MdxScript</ID>
          <Name>MdxScript</Name>
          <CreatedTimestamp>0001-01-01T00:00:00Z</CreatedTimestamp>
          <LastSchemaUpdate>0001-01-01T00:00:00Z</LastSchemaUpdate>
          <Commands>
            <Command>
              <Text>/*
The CALCULATE command controls the aggregation of leaf cells in the cube.
If the CALCULATE command is deleted or modified, the data within the cube is affected.
You should edit this command only if you manually specify how the cube is aggregated.
*/
CALCULATE; 
CREATE MEMBER CURRENTCUBE.[Measures].[Avg Reading Humidity]
 AS [Measures].[Reading Humidity] / [Measures].[Fact Monitoring Count], 
VISIBLE = 1  ; 
CREATE MEMBER CURRENTCUBE.[Measures].[Avg Reading Soil Moisture]
 AS [Measures].[Reading Soil Moisture] / [Measures].[Fact Monitoring Count], 
VISIBLE = 1  ; 
CREATE MEMBER CURRENTCUBE.[Measures].[Avg Reading Soil Ph]
 AS [Measures].[Reading Soil Ph] / [Measures].[Fact Monitoring Count], 
VISIBLE = 1  ;  
CREATE MEMBER CURRENTCUBE.[Measures].[Avg Reading Temperature]
 AS [Measures].[Reading Temperture] / [Measures].[Fact Monitoring Count], 
FORMAT_STRING = "#,##0.00;-#,##0.00", 
VISIBLE = 1; 
CREATE MEMBER CURRENTCUBE.[Measures].[Avg Reading Waterlevel]
 AS [Measures].[Reading Waterlevel] / [Measures].[Fact Monitoring Count], 
VISIBLE = 1  ; 
CREATE MEMBER CURRENTCUBE.[Measures].[Avg Reading Water Ph]
 AS [Measures].[Reading Water Ph] / [Measures].[Fact Monitoring Count], 
VISIBLE = 1  ; </Text>
            </Command>
          </Commands>
        </MdxScript>
      </MdxScripts>
