    <DataSet Name="YearsList">
      <Query>
        <DataSourceName>MonitoringDataV2</DataSourceName>
        <CommandText>WITH MEMBER [Measures].[YearName] AS [Dim Date].[Hierarchy].CurrentMember.Name
SELECT 
  {[Measures].[YearName]} ON COLUMNS,
  NON EMPTY 
  EXCEPT(
    {[Dim Date].[Hierarchy].[Year].MEMBERS},
    {[Dim Date].[Hierarchy].[Year].[All]}
  ) ON ROWS
FROM [Monitoring Cube]</CommandText>
        <rd:DesignerState>
          <QueryDefinition xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://schemas.microsoft.com/AnalysisServices/QueryDefinition">
            <CommandType>DAX</CommandType>
            <QuerySpecification xsi:type="MDXQuerySpecification">
              <Select>
                <Items>
                  <Item>
                    <ID xsi:type="Level">
                      <DimensionName>Dim Date</DimensionName>
                      <HierarchyName>Year</HierarchyName>
                      <HierarchyUniqueName>[Dim Date].[Year]</HierarchyUniqueName>
                      <LevelName>Year</LevelName>
                      <UniqueName>[Dim Date].[Year].[Year]</UniqueName>
                    </ID>
                    <ItemCaption>Year</ItemCaption>
                    <UniqueName>true</UniqueName>
                  </Item>
                  <Item>
                    <ID xsi:type="Level">
                      <DimensionName>Dim Date</DimensionName>
                      <HierarchyName>Date Sk</HierarchyName>
                      <HierarchyUniqueName>[Dim Date].[Date Sk]</HierarchyUniqueName>
                      <LevelName>Date Sk</LevelName>
                      <UniqueName>[Dim Date].[Date Sk].[Date Sk]</UniqueName>
                    </ID>
                    <ItemCaption>Date Sk</ItemCaption>
                    <UniqueName>true</UniqueName>
                  </Item>
                </Items>
              </Select>
              <AutoExecute>false</AutoExecute>
              <From>Monitoring Cube</From>
              <Filter>
                <FilterItems />
              </Filter>
              <Calculations />
              <Aggregates />
              <QueryProperties>
                <IncludeMemberValue>true</IncludeMemberValue>
              </QueryProperties>
            </QuerySpecification>
            <Query>
              <Statement>EVALUATE SUMMARIZECOLUMNS('Dim Date'[Year], 'Dim Date'[Date Sk])</Statement>
              <ParameterDefinitions />
            </Query>
          </QueryDefinition>
        </rd:DesignerState>
      </Query>
      <Fields>
        <Field Name="Year">
          <DataField>Dim Date[Year]</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
