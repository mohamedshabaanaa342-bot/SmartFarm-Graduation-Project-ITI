  <DTS:Executables>
    <DTS:Executable
      DTS:refId="Package\FillDimTime"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{d854e29d-5090-4659-bb0e-cdef0d8b58b7}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="FillDimTime"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{4A7D52DA-F420-4F5B-8182-1EDCD004832E}"
          SQLTask:SqlStatementSource="&#xA;-- 2. تفعيل خاصية إدخال قيم يدوية في عمود الـ Identity&#xA;SET IDENTITY_INSERT [dbo].[Dim_Time] ON;&#xA;&#xA;-- 3. توليد الـ 86,400 ثانية دفعة واحدة في جزء من الثانية&#xA;WITH Digits AS (&#xA;    SELECT TOP 10 row_number() OVER (ORDER BY (SELECT NULL)) - 1 AS d &#xA;    FROM master.dbo.spt_values&#xA;),&#xA;Numbers AS (&#xA;    SELECT (d1.d + d2.d * 10 + d3.d * 100 + d4.d * 1000 + d5.d * 10000) AS n&#xA;    FROM Digits d1 &#xA;    CROSS JOIN Digits d2 &#xA;    CROSS JOIN Digits d3 &#xA;    CROSS JOIN Digits d4 &#xA;    CROSS JOIN Digits d5&#xA;    WHERE (d1.d + d2.d * 10 + d3.d * 100 + d4.d * 1000 + d5.d * 10000) &lt; 86400&#xA;),&#xA;TimeGeneration AS (&#xA;    SELECT &#xA;        n / 3600 AS [h],&#xA;        (n % 3600) / 60 AS [m],&#xA;        n % 60 AS [s]&#xA;    FROM Numbers&#xA;)&#xA;INSERT INTO [dbo].[Dim_Time] ([time_sk], [hour], [minte], [second])&#xA;SELECT &#xA;    -- تركيب الـ SK الرقمي الموزون&#xA;    CAST(&#xA;        RIGHT('0' + CAST([h] AS VARCHAR(2)), 2) + &#xA;        RIGHT('0' + CAST([m] AS VARCHAR(2)), 2) + &#xA;        RIGHT('0' + CAST([s] AS VARCHAR(2)), 2) &#xA;    AS INT) AS [time_sk],&#xA;    [h] AS [hour],&#xA;    [m] AS [minte], -- الاسم الملتزم به في مخططك&#xA;    [s] AS [second]&#xA;FROM TimeGeneration&#xA;ORDER BY [h], [m], [s];&#xA;&#xA;-- 4. إعادة إغلاق الخاصية لحماية الجدول بعد اكتمال الإدخال&#xA;SET IDENTITY_INSERT [dbo].[Dim_Time] OFF;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
