      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{DD53FB33-843C-4015-A5C7-2F49C5B08D4A}"
          SQLTask:SqlStatementSource="&#xA;&#xA;-- 2. تحديد الفترة الزمنية (من سنة 2020 إلى 2030)&#xA;DECLARE @StartDate DATE = '2020-01-01'&#xA;DECLARE @EndDate DATE = '2030-12-31'&#xA;&#xA;WHILE @StartDate &lt;= @EndDate&#xA;BEGIN&#xA;    INSERT INTO [dbo].[Dim_Date] (&#xA;        [date_sk], &#xA;        [Day], &#xA;        [mounth], -- تم الالتزام بالاسم المكتوب في المخطط الخاص بك&#xA;        [year]&#xA;    )&#xA;    VALUES (&#xA;        -- تركيب التاريخ بالكامل بصيغة YYYYMMDD مدمجة رقمياً (مثال: 20260626)&#xA;        CAST(FORMAT(@StartDate, 'yyyyMMdd') AS INT), &#xA;        DAY(@StartDate),&#xA;        MONTH(@StartDate), &#xA;        YEAR(@StartDate)&#xA;    )&#xA;    &#xA;    -- الانتقال لليوم التالي&#xA;    SET @StartDate = DATEADD(day, 1, @StartDate)&#xA;END" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
