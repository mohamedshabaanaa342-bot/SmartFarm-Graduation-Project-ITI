                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">-- 1. تجهيز جدول مؤقت بـ أقل location_sk لكل zone_id لتجنب الـ Subquery البطيء والمسبب للمشكلة
WITH MinLocation AS (
    SELECT 
        zone_id,
        location_sk,
        ROW_NUMBER() OVER (PARTITION BY zone_id ORDER BY location_sk ASC) as rn
    FROM Farm_System_DWH.dbo.Dim_Location
),
UniqueLocation AS (
    SELECT zone_id, location_sk
    FROM MinLocation
    WHERE rn = 1
)

-- الكود الأساسي بتاعك بعد التعديل
SELECT
h.quantity_kg AS crop_yield,
NULL AS eggs_id,
h.harvest_id AS harvest_id,
NULL AS animal_medicine_id,
NULL AS poultry_medicine_id,
dd.date_sk AS date_sk,
da.Assest_catalog_sk AS asset_category_id,
c.crop_name AS crop_name,
h.quantity_kg AS crop_quantity_kg,
NULL AS eggs_collected,
h.quantity_kg AS harvest_quantity_kg,
h.quality_score AS harvest_quality_score,
NULL AS animal_type,
NULL AS animal_medicine_name,
NULL AS animal_dosage,
NULL AS animal_administered,
NULL AS poultry_medicine_name,
NULL AS poultry_dosage,
NULL AS poultry_administered,
rc.resource_id AS resource_id,
dl.location_sk AS loc_sk
FROM Harvest h
INNER JOIN Crop c ON h.crop_id = c.crop_id
LEFT JOIN Resource_Crop rc ON rc.crop_id = c.crop_id
LEFT JOIN Farm_System_DWH.dbo.Dim_Date dd
ON DAY(h.harvest_date) = dd.[Day]
AND MONTH(h.harvest_date) = dd.[mounth]
AND YEAR(h.harvest_date) = dd.[year]
LEFT JOIN Farm_System_DWH.dbo.Dim_Assest_Catalog da
ON da.Crop_id = c.crop_id
-- التعديل هنا: ربط مباشر مع الـ CTE
LEFT JOIN UniqueLocation dl ON dl.zone_id = c.zone_id

UNION ALL

-- EGG PRODUCTION
SELECT
NULL AS crop_yield,
pl.egg_log_id AS eggs_id,
NULL AS harvest_id,
NULL AS animal_medicine_id,
NULL AS poultry_medicine_id,
dd.date_sk AS date_sk,
da.Assest_catalog_sk AS asset_category_id,
NULL AS crop_name,
NULL AS crop_quantity_kg,
pl.eggs_collected AS eggs_collected,
NULL AS harvest_quantity_kg,
NULL AS harvest_quality_score,
p.breed AS animal_type,
NULL AS animal_medicine_name,
NULL AS animal_dosage,
NULL AS animal_administered,
NULL AS poultry_medicine_name,
NULL AS poultry_dosage,
NULL AS poultry_administered,
rp.resource_id AS resource_id,
dl.location_sk AS loc_sk
FROM Poultry_Logs pl
INNER JOIN Poultry p ON pl.poultry_id = p.poultry_id
LEFT JOIN Resource_Poultry rp ON rp.poultry_id = pl.poultry_id
LEFT JOIN Farm_System_DWH.dbo.Dim_Date dd
ON DAY(pl.log_date) = dd.[Day]
AND MONTH(pl.log_date) = dd.[mounth]
AND YEAR(pl.log_date) = dd.[year]
LEFT JOIN Farm_System_DWH.dbo.Dim_Assest_Catalog da
ON da.Poultry_id = pl.poultry_id
-- التعديل هنا: ربط مباشر مع الـ CTE
LEFT JOIN UniqueLocation dl ON dl.zone_id = pl.zone_id

UNION ALL

-- CATTLE MEDICINE
SELECT
NULL AS crop_yield,
NULL AS eggs_id,
NULL AS harvest_id,
cm.med_id AS animal_medicine_id,
NULL AS poultry_medicine_id,
dd.date_sk AS date_sk,
da.Assest_catalog_sk AS asset_category_id,
NULL AS crop_name,
NULL AS crop_quantity_kg,
NULL AS eggs_collected,
NULL AS harvest_quantity_kg,
NULL AS harvest_quality_score,
'Cattle' AS animal_type,
cm.medicine_name AS animal_medicine_name,
cm.dosage AS animal_dosage,
cm.administered_by AS animal_administered,
NULL AS poultry_medicine_name,
NULL AS poultry_dosage,
NULL AS poultry_administered,
rc.resource_id AS resource_id,
dl.location_sk AS loc_sk
FROM Cattle_Medicine cm
INNER JOIN Cattle ca ON ca.cattle_id = cm.Cattle_id
LEFT JOIN Resource_Cattle rc ON rc.cattle_id = cm.Cattle_id
LEFT JOIN Farm_System_DWH.dbo.Dim_Date dd
ON DAY(cm.given_date) = dd.[Day]
AND MONTH(cm.given_date) = dd.[mounth]
AND YEAR(cm.given_date) = dd.[year]
LEFT JOIN Farm_System_DWH.dbo.Dim_Assest_Catalog da
ON da.Cattle_id = cm.Cattle_id
-- التعديل هنا: ربط مباشر مع الـ CTE
LEFT JOIN UniqueLocation dl ON dl.zone_id = ca.zone_id

UNION ALL

-- POULTRY MEDICINE
SELECT
NULL AS crop_yield,
NULL AS eggs_id,
NULL AS harvest_id,
NULL AS animal_medicine_id,
pm.med_id AS poultry_medicine_id,
dd.date_sk AS date_sk,
da.Assest_catalog_sk AS asset_category_id,
NULL AS crop_name,
NULL AS crop_quantity_kg,
NULL AS eggs_collected,
NULL AS harvest_quantity_kg,
NULL AS harvest_quality_score,
'Poultry' AS animal_type,
NULL AS animal_medicine_name,
NULL AS animal_dosage,
NULL AS animal_administered,
pm.medicine_name AS poultry_medicine_name,
pm.dosage AS poultry_dosage,
pm.administered_by AS poultry_administered,
rp.resource_id AS resource_id,
dl.location_sk AS loc_sk
FROM Poultry_Medicine pm
INNER JOIN Poultry p ON p.poultry_id = pm.Poultry_id
LEFT JOIN Resource_Poultry rp ON rp.poultry_id = pm.Poultry_id
LEFT JOIN Farm_System_DWH.dbo.Dim_Date dd
ON DAY(pm.given_date) = dd.[Day]
AND MONTH(pm.given_date) = dd.[mounth]
AND YEAR(pm.given_date) = dd.[year]
LEFT JOIN Farm_System_DWH.dbo.Dim_Assest_Catalog da
ON da.Poultry_id = pm.Poultry_id
-- التعديل هنا: ربط مباشر مع الـ CTE
LEFT JOIN UniqueLocation dl ON dl.zone_id = p.zone_id</property>
